{
  "name": "@filework/desktop",
  "description": "Workspace Agent — general-purpose AI agent for your local workspace, with file ops, shell access, plan execution, and skill extensions.",
  "version": "0.1.0",
  "private": true,
  "main": "out/main/index.js",
  "filework": {
    "type": "derived",
    "version": "0.1.0",
    "features": {
      "auth": false,
      "database": true,
      "trpc": false,
      "openapi": false,
      "i18n": true,
      "documentation": false,
      "billing": false,
      "email": false,
      "ai": true,
      "demo": false,
      "testing": true
    }
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "package": "electron-builder --mac",
    "lint": "biome format . --write && biome check .",
    "lint:err": "biome format . --write && biome check . --write --diagnostic-level=error",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "typesafe-i18n": "typesafe-i18n --no-watch",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.43",
    "@ai-sdk/deepseek": "^2.0.24",
    "@ai-sdk/openai": "^3.0.0",
    "@ai-sdk/react": "^3.0.0",
    "@mozilla/readability": "^0.6.0",
    "@streamdown/cjk": "^1.0.2",
    "@streamdown/code": "^1.0.2",
    "@streamdown/math": "^1.0.2",
    "ai": "^6.0.0",
    "better-sqlite3": "^12.6.2",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.19",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "electron-store": "^11.0.2",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "linkedom": "^0.18.12",
    "lucide-react": "^0.577.0",
    "mammoth": "^1.11.0",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "shiki": "^4.0.2",
    "sonner": "^2.0.7",
    "streamdown": "^2.3.0",
    "superjson": "^2.2.1",
    "tailwind-merge": "^3.5.0",
    "turndown": "^7.2.4",
    "typesafe-i18n": "^5.26.2",
    "undici": "^8.2.0",
    "which": "^6.0.1",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/postcss": "^4.1.17",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.5",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/turndown": "^5.0.6",
    "@types/which": "^3.0.4",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "fast-check": "^4.6.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.17",
    "tsx": "^4.20.5",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "appStatus": {
    "port": null,
    "description": "Workspace Agent (Electron Desktop)",
    "status": "🚧 开发中",
    "specs": {
      "prd": true,
      "icp": true,
      "marketing": true,
      "onboarding": true,
      "designSystem": true,
      "vi": true
    },
    "qualityScore": 100
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "better-sqlite3",
      "esbuild",
      "electron-winstaller"
    ]
  }
}
